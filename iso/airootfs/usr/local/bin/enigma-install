#!/usr/bin/env bash
# enigmaOS guided installer — runs inside the live Arch ISO produced by
# iso/build-iso.sh. Does the *base* Arch install (partition, pacstrap,
# systemd-boot, user, network), drops the baked-in enigmaOS repo into the
# new user's ~/src/enigmaOS, then arms a one-shot first-boot autologin that
# runs enigmaOS's own install.sh (the desktop layer) in its native
# environment and reboots into SDDM.
#
# Layers deliberately stay split: THIS script only builds a bootable,
# networked Arch box with a sudo user. Everything Hyprland is install.sh's
# job, run on first boot where a real user session + network exist.
set -uo pipefail

# ---- Tunables (edit before building the ISO if you like) -------------------
LOCALE="en_US.UTF-8"
KEYMAP="us"
TIMEZONE="Europe/Stockholm"
# Minimal base: enough to boot, get on the network, and let install.sh do the
# rest. install.sh's core.txt re-lists most of these; pacman --needed skips.
# tpm2-tss lets systemd-cryptenroll / the initramfs talk to the TPM.
BASE_PACKAGES=(base linux linux-firmware sudo networkmanager git base-devel stow vim cryptsetup tpm2-tss)
# TPM2 keyslot binds to these PCRs (comma/plus separated). 7 = Secure Boot
# state — the most update-stable choice; adds modest tamper-evidence without
# breaking on every kernel/firmware bump. Set empty for none (PIN + TPM only).
TPM_PCRS="7"
# Where build-iso.sh baked this repo into the live filesystem (a tarball,
# because mkarchiso strips file modes off plain airootfs trees).
REPO_SRC="/usr/local/share/enigmaOS.tar.gz"
# -----------------------------------------------------------------------------

c_blue=$'\033[1;34m'; c_red=$'\033[1;31m'; c_grn=$'\033[1;32m'; c_ylw=$'\033[1;33m'; c_rst=$'\033[0m'
log()  { printf '%s[enigma-install]%s %s\n' "$c_blue" "$c_rst" "$*"; }
ok()   { printf '%s[enigma-install]%s %s\n' "$c_grn" "$c_rst" "$*"; }
warn() { printf '%s[enigma-install] WARNING:%s %s\n' "$c_ylw" "$c_rst" "$*" >&2; }
die()  { printf '%s[enigma-install] ERROR:%s %s\n' "$c_red" "$c_rst" "$*" >&2; exit 1; }

trap 'die "aborted at line $LINENO. If partitioning had already started, the target disk may be in a half-written state — just re-run and it repartitions from scratch."' ERR
set -E

[[ $EUID -eq 0 ]] || die "run as root (you should already be root in the live ISO)."
[[ -d /sys/firmware/efi/efivars ]] || die "not booted in UEFI mode. Reboot the USB in UEFI (disable CSM/Legacy)."
[[ -f "$REPO_SRC" ]] || die "baked repo missing at $REPO_SRC — was this ISO built with build-iso.sh?"

banner() {
    cat <<'EOF'

          __________________________________
         |                                  |
         |   enigma > hello, world_         |
  _______|__________________________________|______
  | (O)===(_______________________________)===(O) |
  |                                               |
  |   /      (Q)(W)(E)(R)(T)(Z)(U)(I)(O)      \   |
  |  /        (A)(S)(D)(F)(G)(H)(J)(K)         \  |
  | /        (P)(Y)(X)(C)(V)(B)(N)(M)(L)        \ |
  |_______________________________________________|

               _                       ____  _____
   ___  ____  (_)___ _____ ___  ____ _/ __ \/ ___/
  / _ \/ __ \/ / __ `/ __ `__ \/ __ `/ / / /\__ \
 /  __/ / / / / /_/ / / / / / / /_/ / /_/ /___/ /
 \___/_/ /_/_/\__, /_/ /_/ /_/\__,_/\____//____/
             /____/

       Arch + Hyprland, from bare metal  ::  guided installer
EOF
    echo
    echo "This will ERASE a disk of your choosing and install Arch + enigmaOS."
    echo "Ctrl-C at any prompt to bail out to a shell."
    echo
}

# ---- 1. Network -------------------------------------------------------------
ensure_network() {
    if ping -c1 -W2 archlinux.org &>/dev/null; then
        ok "Network is up."
        return
    fi
    log "No connectivity yet. Wired connections usually come up on their own."
    read -rp "Configure Wi-Fi now? [Y/n] " a
    [[ "${a,,}" == n* ]] && { ping -c1 -W2 archlinux.org &>/dev/null || die "still offline; connect a cable or configure Wi-Fi, then re-run: enigma-install"; return; }

    local dev ssid pass w
    dev=""
    for w in /sys/class/net/*/wireless; do
        [[ -e "$w" ]] || continue
        dev=$(basename "$(dirname "$w")")
        break
    done
    [[ -n "$dev" ]] || die "no Wi-Fi interface found (none of /sys/class/net/*/wireless exist)."
    local i
    while :; do
        log "Scanning on $dev ..."
        iwctl station "$dev" scan || warn "scan failed — the network list below may be stale."
        sleep 2
        iwctl station "$dev" get-networks || true
        read -rp "SSID: " ssid
        read -rsp "Passphrase: " pass; echo
        if ! iwctl --passphrase "$pass" station "$dev" connect "$ssid"; then
            warn "Wi-Fi connect failed (wrong SSID or passphrase?) — let's try again. Ctrl-C to bail."
            continue
        fi
        log "Waiting for connectivity ..."
        for i in {1..20}; do ping -c1 -W1 archlinux.org &>/dev/null && break; sleep 1; done
        ping -c1 -W2 archlinux.org &>/dev/null && break
        warn "Connected to '$ssid' but still no internet — let's try again. Ctrl-C to bail."
    done
    ok "Wi-Fi connected."
    WIFI_SSID="$ssid"; WIFI_PSK="$pass"   # persisted to the target for first boot
}

# ---- 2. Gather answers ------------------------------------------------------
choose_disk() {
    echo; echo "Available disks:"
    lsblk -dpno NAME,SIZE,MODEL | grep -vE 'loop|/dev/sr' | nl -w2 -s') '
    echo
    read -rp "Target disk (full path, e.g. /dev/nvme0n1): " DISK
    [[ -b "$DISK" ]] || die "'$DISK' is not a block device."
    lsblk -no MOUNTPOINT "$DISK" 2>/dev/null | grep -q '^/run/archiso' \
        && die "'$DISK' looks like the USB you booted from. Pick the internal disk."
    echo
    lsblk "$DISK"
    echo
    printf '%sEVERYTHING on %s will be destroyed.%s\n' "$c_red" "$DISK" "$c_rst"
    read -rp "Type YES (uppercase) to continue: " confirm
    [[ "$confirm" == "YES" ]] || die "not confirmed."
}

gather() {
    read -rp "Hostname [enigma]: " HOSTNAME; HOSTNAME="${HOSTNAME:-enigma}"
    while :; do
        read -rp "Username: " USERNAME
        [[ "$USERNAME" =~ ^[a-z_][a-z0-9_-]*$ ]] && break
        echo "  invalid (lowercase, start with letter/underscore)."
    done
    while :; do
        read -rsp "Password for $USERNAME: " PASS1; echo
        read -rsp "Repeat password: " PASS2; echo
        [[ -n "$PASS1" && "$PASS1" == "$PASS2" ]] && break
        echo "  empty or mismatch, try again."
    done
    USERPASS="$PASS1"; unset PASS1 PASS2

    read -rp "Encrypt the disk with LUKS? [Y/n] " a
    if [[ "${a,,}" == n* ]]; then
        ENCRYPT=0
    else
        ENCRYPT=1
        read -rp "Enroll TPM2 + PIN auto-unlock on first boot? [Y/n] " a2
        [[ "${a2,,}" == n* ]] && TPM_ENROLL=0 || TPM_ENROLL=1
        if [[ "$TPM_ENROLL" == 1 ]]; then
            echo "  (the disk passphrase below becomes a RECOVERY key; day to day you'll"
            echo "   type a short PIN at boot. The PIN itself is set on first boot.)"
        else
            echo "  (you'll type this passphrase at every boot to unlock the disk)"
        fi
        while :; do
            read -rsp "Disk encryption passphrase (recovery key): " LP1; echo
            read -rsp "Repeat passphrase: " LP2; echo
            [[ -n "$LP1" && "$LP1" == "$LP2" ]] && break
            echo "  empty or mismatch, try again."
        done
        LUKSPASS="$LP1"; unset LP1 LP2
    fi
}

# ---- 3. Partition + format --------------------------------------------------
partdev() {  # partdev <disk> <n> -> handles nvme0n1p1 vs sda1
    local d="$1" n="$2"
    [[ "$d" == *[0-9] ]] && echo "${d}p${n}" || echo "${d}${n}"
}

do_disk() {
    EFI_PART=$(partdev "$DISK" 1); ROOT_PART=$(partdev "$DISK" 2)
    local scheme="1GiB EFI + rest ext4 root"
    [[ "$ENCRYPT" == 1 ]] && scheme="1GiB EFI + rest LUKS2-encrypted ext4 root"
    log "Wiping $DISK and creating GPT ($scheme)."
    umount -R /mnt 2>/dev/null || true
    swapoff -a 2>/dev/null || true
    cryptsetup close cryptroot 2>/dev/null || true
    wipefs -af "$DISK"
    sgdisk --zap-all "$DISK"
    sgdisk -n1:0:+1GiB -t1:ef00 -c1:EFI \
           -n2:0:0     -t2:8300 -c2:root "$DISK"
    partprobe "$DISK"; sleep 1
    # A previous install's signatures survive repartitioning (same layout ->
    # same offsets), and mkfs.ext4 leaves a stale LUKS magic at offset 0
    # intact — blkid then still calls the partition crypto_LUKS and mount
    # refuses it. Wipe signatures per-partition; whole-disk wipefs above only
    # clears the partition table, not what's inside the partitions.
    wipefs -af "$EFI_PART" "$ROOT_PART"
    mkfs.fat -F32 -n EFI "$EFI_PART"

    if [[ "$ENCRYPT" == 1 ]]; then
        # Encrypt the root partition only; the ESP (/boot) stays plain so
        # systemd-boot can read the kernel + initramfs. The `encrypt` mkinitcpio
        # hook (added in configure_system) unlocks it at boot via the cmdline.
        log "Creating LUKS2 container on $ROOT_PART (slow key derivation) ..."
        printf '%s' "$LUKSPASS" | cryptsetup luksFormat --type luks2 --batch-mode "$ROOT_PART" -
        log "Unlocking it as /dev/mapper/cryptroot ..."
        printf '%s' "$LUKSPASS" | cryptsetup open "$ROOT_PART" cryptroot -
        ROOT_FS=/dev/mapper/cryptroot
        LUKS_UUID=$(blkid -s UUID -o value "$ROOT_PART")
    else
        ROOT_FS="$ROOT_PART"
    fi

    mkfs.ext4 -F -L root "$ROOT_FS"
    mount "$ROOT_FS" /mnt
    mount --mkdir "$EFI_PART" /mnt/boot
}

# ---- 4. Base system ---------------------------------------------------------
do_pacstrap() {
    if grep -qi 'GenuineIntel' /proc/cpuinfo; then UCODE_PKG=intel-ucode; UCODE_IMG=intel-ucode.img
    else UCODE_PKG=amd-ucode; UCODE_IMG=amd-ucode.img; fi
    log "Installing base system (pacstrap) — this pulls packages over the network."
    pacstrap -K /mnt "${BASE_PACKAGES[@]}" "$UCODE_PKG"
    genfstab -U /mnt >> /mnt/etc/fstab
    # give the chroot a resolver for the first-boot/AUR steps that come later
    cp -f /etc/resolv.conf /mnt/etc/resolv.conf 2>/dev/null || true
}

configure_system() {
    log "Configuring locale, time, hostname, bootloader, user."
    local cmdline luks_uuid=""
    if [[ "$ENCRYPT" == 1 ]]; then
        # sd-encrypt reads /etc/crypttab.initramfs for the mapping, so the
        # cmdline only names the resulting root device.
        cmdline="root=/dev/mapper/cryptroot rw"
        luks_uuid="$LUKS_UUID"
    else
        cmdline="root=PARTUUID=$(blkid -s PARTUUID -o value "$ROOT_PART") rw"
    fi

    arch-chroot /mnt /bin/bash -s -- \
        "$TIMEZONE" "$LOCALE" "$KEYMAP" "$HOSTNAME" "$USERNAME" "$UCODE_IMG" "$cmdline" "$ENCRYPT" "$luks_uuid" <<'CHROOT'
set -euo pipefail
TIMEZONE="$1"; LOCALE="$2"; KEYMAP="$3"; HOSTNAME="$4"; USERNAME="$5"; UCODE_IMG="$6"; CMDLINE="$7"; ENCRYPT="$8"; LUKS_UUID="$9"

ln -sf "/usr/share/zoneinfo/$TIMEZONE" /etc/localtime
hwclock --systohc

sed -i "s/^#\s*\(${LOCALE//./\\.} \)/\1/" /etc/locale.gen
grep -q "^${LOCALE} " /etc/locale.gen || echo "${LOCALE} UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=$LOCALE" > /etc/locale.conf
echo "KEYMAP=$KEYMAP" > /etc/vconsole.conf

echo "$HOSTNAME" > /etc/hostname
cat > /etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   $HOSTNAME.localdomain $HOSTNAME
HOSTS

# encrypted root: use the systemd-based initramfs + sd-encrypt hook (this is
# what supports TPM2 unlocking). crypttab.initramfs defines the mapping;
# `tpm2-device=auto` makes early boot try the TPM (and prompt for the PIN once
# a keyslot is enrolled on first boot), falling back to the passphrase.
if [[ "$ENCRYPT" == 1 ]]; then
    sed -i 's/^HOOKS=.*/HOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole block sd-encrypt filesystems fsck)/' /etc/mkinitcpio.conf
    echo "cryptroot UUID=$LUKS_UUID - tpm2-device=auto" > /etc/crypttab.initramfs
    mkinitcpio -P
fi

# systemd-boot on the ESP mounted at /boot
bootctl --esp-path=/boot install
cat > /boot/loader/loader.conf <<LOADER
default enigma.conf
timeout 3
console-mode max
editor no
LOADER
cat > /boot/loader/entries/enigma.conf <<ENTRY
title   EnigmaOS
linux   /vmlinuz-linux
initrd  /$UCODE_IMG
initrd  /initramfs-linux.img
options $CMDLINE
ENTRY

# user + sudo (root stays locked; wheel gets sudo)
useradd -m -G wheel -s /bin/bash "$USERNAME"
install -d -m750 /etc/sudoers.d
echo '%wheel ALL=(ALL:ALL) ALL' > /etc/sudoers.d/10-wheel
chmod 0440 /etc/sudoers.d/10-wheel
passwd -l root

# network on first boot
systemctl enable NetworkManager.service
CHROOT

    # set the user's password (kept out of the process table / heredoc above)
    printf '%s:%s\n' "$USERNAME" "$USERPASS" | arch-chroot /mnt chpasswd
}

# ---- 5. Ship the repo + arm the first-boot desktop install ------------------
deploy_repo_and_firstboot() {
    local home="/mnt/home/$USERNAME"
    log "Extracting enigmaOS repo -> ~$USERNAME/src/enigmaOS"
    install -d "$home/src/enigmaOS"
    tar -xzf "$REPO_SRC" -C "$home/src/enigmaOS"

    # skel ships .bashrc/.bash_profile; enigmaOS stows its own .bashrc, so a
    # pre-existing one makes stow abort. Clear the skel defaults for a clean
    # target (system-wide /etc/profile still drives our first-boot launcher).
    rm -f "$home/.bashrc" "$home/.bash_profile" "$home/.bash_logout"
    arch-chroot /mnt chown -R "$USERNAME:$USERNAME" "/home/$USERNAME/src" "/home/$USERNAME" 2>/dev/null || true

    # persist Wi-Fi so the first boot is online before install.sh runs
    if [[ -n "${WIFI_SSID:-}" ]]; then
        log "Persisting Wi-Fi credentials for first boot."
        install -d -m700 /mnt/etc/NetworkManager/system-connections
        cat > "/mnt/etc/NetworkManager/system-connections/$WIFI_SSID.nmconnection" <<NMCONN
[connection]
id=$WIFI_SSID
type=wifi
[wifi]
mode=infrastructure
ssid=$WIFI_SSID
[wifi-security]
key-mgmt=wpa-psk
psk=$WIFI_PSK
[ipv4]
method=auto
[ipv6]
method=auto
NMCONN
        chmod 600 "/mnt/etc/NetworkManager/system-connections/$WIFI_SSID.nmconnection"
    fi

    log "Arming first-boot desktop install (autologin on tty1 -> install.sh)."
    install -d -m755 /mnt/var/lib/enigma
    touch /mnt/var/lib/enigma/firstboot-pending

    # config read by enigma-firstboot (TPM enrollment happens there, on the
    # real boot, so the PCR measurements match the installed system)
    cat > /mnt/var/lib/enigma/firstboot.env <<ENV
TPM_ENROLL=${TPM_ENROLL:-0}
TPM_PCRS=$TPM_PCRS
ENIGMA_USER=$USERNAME
ENV

    # temporary passwordless sudo so the unattended first boot doesn't stall.
    # 'zz-' so it sorts AFTER 10-wheel: sudoers applies the LAST matching
    # rule, and wheel's passworded rule would otherwise override this one.
    echo "$USERNAME ALL=(ALL) NOPASSWD: ALL" > /mnt/etc/sudoers.d/zz-enigma-firstboot
    chmod 0440 /mnt/etc/sudoers.d/zz-enigma-firstboot

    # autologin the user on tty1
    install -d -m755 /mnt/etc/systemd/system/getty@tty1.service.d
    cat > /mnt/etc/systemd/system/getty@tty1.service.d/enigma-autologin.conf <<AUTOLOGIN
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin $USERNAME --noclear %I \$TERM
AUTOLOGIN

    # launcher: fires only for our user, on a CONSOLE login on tty1, while the
    # sentinel exists. The session-type check matters: SDDM's wayland-session
    # wrapper re-execs bash --login (sourcing /etc/profile.d) and the graphical
    # session owns tty1, so without it this hijacks every SDDM login and runs
    # install.sh inside the black screen where the compositor should be.
    cat > /mnt/etc/profile.d/zzz-enigma-firstboot.sh <<LAUNCH
# enigmaOS one-shot desktop install on first boot
if [ -f /var/lib/enigma/firstboot-pending ] \\
   && [ "\$(id -un)" = "$USERNAME" ] \\
   && [ "\${XDG_SESSION_TYPE:-}" = "tty" ] \\
   && [ "\$(tty)" = "/dev/tty1" ]; then
    /usr/local/sbin/enigma-firstboot
fi
LAUNCH

    cat > /mnt/usr/local/sbin/enigma-firstboot <<'FIRSTBOOT'
#!/usr/bin/env bash
# One-shot: run enigmaOS install.sh on the freshly installed system, then
# clean up the autologin/sudo scaffolding and reboot into SDDM. Left armed
# (so a re-login retries) if install.sh fails.
set -uo pipefail

[ -f /var/lib/enigma/firstboot.env ] && . /var/lib/enigma/firstboot.env
ENIGMA_USER="${ENIGMA_USER:-$(id -un)}"
ENIGMA_HOME=$(getent passwd "$ENIGMA_USER" | cut -d: -f6)

# Retried with sudo? Re-run as the real user so the repo path resolves and
# AUR builds don't run as root. (No login shell here — that would re-trigger
# the profile.d launcher and run this script twice.)
if [ "$(id -u)" -eq 0 ] && [ "$ENIGMA_USER" != root ]; then
    echo "[enigma-firstboot] running as root — re-running as $ENIGMA_USER."
    exec runuser -u "$ENIGMA_USER" -- env HOME="$ENIGMA_HOME" \
        USER="$ENIGMA_USER" LOGNAME="$ENIGMA_USER" /usr/local/sbin/enigma-firstboot
fi

echo
echo "=============================================================="
echo " enigmaOS: installing the Hyprland desktop layer (first boot)."
echo " This runs ~/src/enigmaOS/install.sh. Grab a coffee — AUR"
echo " builds take a while. On success it reboots into the login screen."
echo "=============================================================="
echo

echo "[enigma-firstboot] waiting for network ..."
for _ in $(seq 1 60); do
    ping -c1 -W1 archlinux.org &>/dev/null && break
    sleep 2
done
if ! ping -c1 -W1 archlinux.org &>/dev/null; then
    echo "[enigma-firstboot] still offline. Connect (nmtui) then re-login on tty1 to retry."
    exit 0
fi

# --- TPM2 + PIN enrollment (done here, on the real boot, so the PCR values
# match the installed system; the passphrase set at install stays as recovery)
if [ "${TPM_ENROLL:-0}" = 1 ]; then
    backing=$(sudo cryptsetup status cryptroot 2>/dev/null | awk '/device:/{print $2}')
    if [ ! -e /sys/class/tpm/tpm0 ]; then
        echo "[enigma-firstboot] no TPM2 detected — keeping passphrase unlock."
    elif [ -z "$backing" ]; then
        echo "[enigma-firstboot] could not find the LUKS device — skipping TPM enrollment."
    elif sudo cryptsetup luksDump "$backing" | grep -qi 'tpm2'; then
        echo "[enigma-firstboot] TPM2 keyslot already present — skipping enrollment."
    else
        echo
        echo "[enigma-firstboot] Enrolling TPM2 + PIN unlock on $backing."
        echo "  You'll be asked for the DISK PASSPHRASE (recovery key, to authorize),"
        echo "  then to choose a PIN you'll type at boot from now on."
        if sudo systemd-cryptenroll --tpm2-device=auto --tpm2-with-pin=yes \
               ${TPM_PCRS:+--tpm2-pcrs="$TPM_PCRS"} "$backing"; then
            echo "[enigma-firstboot] TPM enrolled. Next boot asks for the PIN; the"
            echo "  passphrase still works as a recovery key."
        else
            echo "[enigma-firstboot] TPM enrollment failed — passphrase unlock still works."
            echo "  You can retry later:  sudo systemd-cryptenroll --tpm2-device=auto --tpm2-with-pin=yes $backing"
        fi
        echo
    fi
fi

cd "$ENIGMA_HOME/src/enigmaOS" || { echo "repo missing at $ENIGMA_HOME/src/enigmaOS"; exit 1; }
# bash, not ./: immune to a lost exec bit on the copied repo
if bash ./install.sh; then
    echo "[enigma-firstboot] desktop install complete — cleaning up."
    sudo rm -f /var/lib/enigma/firstboot-pending
    sudo rm -f /etc/profile.d/zzz-enigma-firstboot.sh
    sudo rm -f /etc/systemd/system/getty@tty1.service.d/enigma-autologin.conf
    sudo rmdir /etc/systemd/system/getty@tty1.service.d 2>/dev/null || true
    echo "[enigma-firstboot] rebooting into SDDM in 5s ..."
    sleep 5
    # the sudoers rm deletes our own NOPASSWD rule, so it must come LAST and
    # the reboot must ride in the same sudo invocation — a later separate
    # sudo would hang on a password prompt nobody can see
    sudo sh -c 'rm -f /etc/sudoers.d/zz-enigma-firstboot /etc/sudoers.d/00-enigma-firstboot; systemctl reboot'
else
    rc=$?
    echo
    echo "[enigma-firstboot] install.sh FAILED (exit $rc)."
    echo "Fix the issue, then re-run:  cd ~/src/enigmaOS && bash install.sh"
    echo "Autologin stays on until it succeeds; re-login on tty1 to retry."
fi
FIRSTBOOT
    chmod 0755 /mnt/usr/local/sbin/enigma-firstboot
}

# ---- main -------------------------------------------------------------------
WIFI_SSID=""; WIFI_PSK=""; ENCRYPT=0; TPM_ENROLL=0
banner
ensure_network
choose_disk
gather
do_disk
do_pacstrap
configure_system
deploy_repo_and_firstboot

umount -R /mnt 2>/dev/null || true
echo
ok "Base install done. Remove the USB and reboot."
if [[ "$ENCRYPT" == 1 ]]; then
    ok "First boot unlocks with your recovery PASSPHRASE."
    [[ "$TPM_ENROLL" == 1 ]] && ok "During first boot you'll set a PIN; every boot after that asks for the PIN."
fi
ok "It then auto-logs in on tty1 and installs the Hyprland desktop,"
ok "and reboots into the SDDM login screen. Pick the 'Hyprland (uwsm)' session."
echo
read -rp "Reboot now? [y/N] " r
[[ "${r,,}" == y* ]] && systemctl reboot
